{{!
    @template local_examnotice/modal

    Exam preparation notice modal.

    Context variables:
    * title   - Modal heading text (auto-escaped)
    * name    - Quiz name (auto-escaped)
    * days    - Integer: days until quiz opens
    * date    - Formatted date string (auto-escaped)
    * content - Raw HTML body content (admin-configured, rendered as-is)

    Example context (PHP):
    [
        'title'   => 'Exam Preparation Instructions',
        'name'    => 'Semester 1 Anatomy Exam',
        'days'    => 5,
        'date'    => '28 Mar 2026',
        'content' => '<ul>...</ul>',
    ]
}}

<!-- local_examnotice -->
<div class="modal fade" id="examNoticeModal" tabindex="-1" role="dialog"
     aria-labelledby="examNoticeModalLabel"
     data-bs-backdrop="static" data-bs-keyboard="false"
     data-backdrop="static" data-keyboard="false">

  <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
    <div class="modal-content">

      <!-- HEADER -->
      <div class="en-header">
        <h4 class="en-title" id="examNoticeModalLabel">{{title}}</h4>
      </div>

      <!-- BODY -->
      <div class="modal-body">
        <div class="en-badge">
          <span>⏰</span>
          <span>
            {{#str}} examnotice_badge_prefix, local_examnotice {{/str}}
            <strong>{{name}}</strong>
            {{#str}} examnotice_badge_opens_in, local_examnotice {{/str}}
            <strong>{{days}} {{#str}} examnotice_badge_days, local_examnotice {{/str}}</strong>
            — {{date}}
          </span>
        </div>

        {{{content}}}
      </div>

      <!-- FOOTER -->
      <div class="en-footer">
        <button type="button" class="en-btn-dismiss" id="examNoticeDismiss">
          🔔 {{#str}} remind_later, local_examnotice {{/str}}
        </button>

        <button type="button" class="en-btn-confirm" id="examNoticeConfirm">
          ✅ {{#str}} confirm_read, local_examnotice {{/str}}
        </button>
      </div>

    </div>
  </div>
</div>