<?xml version="1.0" encoding="UTF-8"?>
<XMLDB PATH="local/examnotice/db" VERSION="20240101"
    COMMENT="XMLDB file for local_examnotice"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd">

    <TABLES>

        <TABLE NAME="local_examnotice_seen" COMMENT="Exam notice tracking table">

            <FIELDS>

                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true" COMMENT="Primary key"/>
                <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" COMMENT="User ID"/>
                <FIELD NAME="quizid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" COMMENT="Quiz ID"/>
                <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" COMMENT="Course ID"/>
                <FIELD NAME="status" TYPE="int" LENGTH="2" NOTNULL="true" DEFAULT="0" COMMENT="Status flag"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" COMMENT="Time created"/>
                <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" COMMENT="Time modified"/>

            </FIELDS>

            <KEYS>

                <KEY NAME="primary" TYPE="primary" FIELDS="id" COMMENT="Primary key"/>

            </KEYS>

            <INDEXES>

                <INDEX NAME="userid_quizid" UNIQUE="true" FIELDS="userid, quizid" COMMENT="User quiz unique index"/>
                <INDEX NAME="userid" UNIQUE="false" FIELDS="userid" COMMENT="User index"/>
                <INDEX NAME="quizid" UNIQUE="false" FIELDS="quizid" COMMENT="Quiz index"/>

            </INDEXES>

        </TABLE>

    </TABLES>

</XMLDB>